{
  "name": "@agent-ctrl/client",
  "version": "0.1.0",
  "description": "TypeScript client for the agent-ctrl daemon.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
